# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase service role key. NEVER prefix with NEXT_PUBLIC_.
# Used only in API routes / server components for admin writes (stock, sales).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Store config (replaces the old <style> :root hardcoded values)
NEXT_PUBLIC_STORE_NAME="Royal Pees Fashion"
NEXT_PUBLIC_STORE_TAGLINE="Bespoke Sultan, Agbada, Senator Attires & Supplies"
NEXT_PUBLIC_WA_PHONE=2348038885167

# ---- SEO ----
# Your real production domain, no trailing slash. Used for canonical tags,
# sitemap.xml, robots.txt, and Open Graph/Twitter share previews.
# Set this to the .vercel.app URL until you buy a custom domain, then update it.
NEXT_PUBLIC_SITE_URL=https://royalpeesfashion.vercel.app

# Longer, keyword-relevant description for meta tags + LocalBusiness schema.
# Distinct from the short STORE_TAGLINE shown in the header UI.
NEXT_PUBLIC_STORE_DESCRIPTION="Royal Pees Fashion House designs and tailors bespoke Agbada, Senator wear, and Sultan Kaftans for weddings, chieftaincy events, and formal occasions across Nigeria. Book a custom fitting via WhatsApp."

# City/region used in LocalBusiness structured data, for local search
# ("agbada tailor Owerri" style queries).
NEXT_PUBLIC_STORE_CITY=Owerri
NEXT_PUBLIC_STORE_REGION="Imo State"

# Admin PIN — server-side only, checked in app/api/admin/auth/route.ts.
# Never exposed to the client bundle.
ADMIN_PIN=change-me-to-a-real-pin

# Random 32+ char secret used to sign the admin session cookie
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
